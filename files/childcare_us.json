{"metrics": [{"id": "spending_pct_gdp_narrow", "name": "Government childcare spending (% of GDP)", "prefix": "", "suffix": "%", "decimals": 2, "source": "Author", "description": "Public spending on ECEC (excluding kindergarten): CCDF, Head Start, MIECHV, state pre-K (NIEER), TANF childcare, IDEA, SSBG, CDCTC, CACFP, and other estimated programs.", "caveat": "Does not include kindergarten."}, {"id": "spending_pct_gdp_broad", "name": "Family benefits spending (% of GDP)", "prefix": "", "suffix": "%", "decimals": 2, "source": "Author", "description": "Broad family benefits: all childcare spending (narrow tier) plus TANF basic cash, WIC, state paid family leave, state EITC, federal EITC (family portion), and Child Tax Credit.", "caveat": "Does not include kindergarten. Includes child and family benefits and tax credits."}, {"id": "wage_ratio_pct", "name": "Childcare & preschool worker wage / median wage (%)", "prefix": "", "suffix": "%", "decimals": 1, "source": "BLS OEWS May 2024 (US); Eurostat SES + national agencies (Nordics); ESDC Job Bank (Canada).", "description": "Childcare and preschool worker wages as a share of the overall median wage.", "caveat": "US: SOC 39-9011 (childcare workers) + 25-2011 (preschool teachers), employment-weighted composite. Nordics: ISCO 5311 (childcare workers) + 2342 (early childhood educators). Canada: NOC 42202 (early childhood educators and assistants, broader group). Kindergarten teachers excluded in all countries."}, {"id": "wage_ratio_cc_pct", "name": "Childcare worker wage / median wage (%)", "prefix": "", "suffix": "%", "decimals": 1, "source": "Author", "description": "Childcare worker wages only (excluding preschool teachers) as a share of the overall median wage.", "caveat": ""}, {"id": "wage_ratio_pt_pct", "name": "Preschool teacher wage / median wage (%)", "prefix": "", "suffix": "%", "decimals": 1, "source": "Author", "description": "Preschool teacher wages as a share of the overall median wage.", "caveat": ""}, {"id": "wa