{
  "metrics": [
    {
      "id": "spending_pct_gdp_narrow",
      "name": "Government childcare spending (% of GDP)",
      "prefix": "",
      "suffix": "%",
      "decimals": 2,
      "source": "Multiple federal + state sources (US); OECD SOCX TP521 (Nordics, Canada).",
      "description": "Public spending on ECEC and kindergarten: CCDF, Head Start, MIECHV, state pre-K (NIEER), TANF childcare, IDEA, SSBG, kindergarten, CDCTC, CACFP, and other estimated programs.",
      "caveat": "US figure is a bottom-up tally including CACFP, CDCTC, and kindergarten, which may differ from the OECD SOCX TP521 figure used for Canada and Nordics. US: FY2022-2024 mixed; Canada: 2022; Nordics: 2021. Canada provinces not shown (no subnational ECEC breakdown exists)."
    },
    {
      "id": "spending_pct_gdp_broad",
      "name": "Family benefits spending (% of GDP)",
      "prefix": "",
      "suffix": "%",
      "decimals": 2,
      "source": "Multiple federal + state sources (US); OECD SOCX (Nordics); StatCan COFOG 7104 (Canada).",
      "description": "Broad family benefits: all childcare spending (narrow tier) plus TANF basic cash, WIC, state paid family leave, state EITC, federal EITC (family portion), and Child Tax Credit.",
      "caveat": "US: IRS SOI TY2022 for tax credits, FY2024 for program spending. Canada: COFOG 7104 'Family and children' (includes child welfare, not just childcare); 2024. Nordics: OECD SOCX TP51 'Family'; 2021."
    },
    {
      "id": "wage_ratio_pct",
      "name": "Childcare & preschool worker wage / median wage (%)",
      "prefix": "",
      "suffix": "%",
      "decimals": 1,
      "source": "BLS OEWS May 2024 (US); Eurostat SES + national agencies (Nordics); ESDC Job Bank (Canada).",
      "description": "Childcare and preschool worker wages as a share of the overall median wage.",
      "caveat": "US: SOC 39-9011 (childcare workers) + 25-2011 (preschool teachers), employment-weighted composite. Nordics: ISCO 5311 (childcare workers) + 2342 (early childhood educators). Canada: NOC 42202 (early childhood educators and assistants, broader group). Kindergarten teachers excluded in all countries."
    },
    {
      "id": "enrollment_pct",
      "name": "Early childhood enrollment rate, ages 0-5 (%)",
      "prefix": "",
      "suffix": "%",
      "decimals": 1,
      "source": "NIEER + Head Start + CPS K rate (US); OECD UOE (Nordics); StatCan SELCCA (Canada).",
      "description": "Share of children aged 0-5 enrolled in formal early childhood education or care.",
      "caveat": "Not directly comparable across countries. US counts public programs only (state pre-K + Head Start + kindergarten, 2024). Nordics count all formal ECEC, public + private (OECD, 2023). Canada counts all care arrangements (SELCCA, 2025)."
    },
    {
      "id": "gdp_per_child_0_5",
      "name": "GDP per child aged 0-5 (millions USD)",
      "prefix": "$",
      "suffix": "M",
      "decimals": 2,
      "source": "BEA + ACS 2023 (US); StatCan (Canada); Eurostat (Nordics); FRED exchange rates.",
      "description": "Total GDP divided by the population aged 0-5, converted to millions of USD.",
      "caveat": "Converted to USD at market exchange rates (FRED, annual average). Sensitive to currency fluctuations. US + Canada: 2023 GDP and population. Nordics: 2023."
    },
    {
      "id": "workforce_share_pct",
      "name": "Childcare & preschool workers as share of workforce (%)",
      "prefix": "",
      "suffix": "%",
      "decimals": 2,
      "source": "BLS OEWS (US); Eurostat + national agencies (Nordics); StatCan LFS (Canada).",
      "description": "Childcare and preschool workers as a percentage of total employment.",
      "caveat": "US: SOC 39-9011 + 25-2011 (childcare workers + preschool teachers). Nordics: ISCO 5311 + 2342 (childcare workers + early childhood educators). Canada: NOC 422 (broader paraprofessional group). Definitions differ in scope; direct cross-country comparison is approximate."
    }
  ],
