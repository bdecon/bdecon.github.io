{
  "metrics": [
    {
      "id": "spending_pct_gdp",
      "name": "Government childcare spending (% of GDP)",
      "prefix": "",
      "suffix": "%",
      "decimals": 2,
      "source": "Author calculations; OECD; national statistical agencies.",
      "description": "Government spending on childcare and early education as a share of GDP.",
      "caveat": "US figures are partial estimates (CCDF, Head Start, state pre-K) that likely undercount total public investment. Canada uses broad 'Family and children' spending, which includes cash benefits and is not directly comparable."
    },
    {
      "id": "wage_ratio_pct",
      "name": "Childcare worker wage / median wage (%)",
      "prefix": "",
      "suffix": "%",
      "decimals": 1,
      "source": "BLS OEWS (US); national statistical agencies.",
      "description": "Childcare worker wages as a share of the overall median wage.",
      "caveat": "Occupation definitions differ (US SOC, Nordic ISCO, Canada NOC). US excludes higher-paid preschool teachers. Canada uses a broader occupation group."
    },
    {
      "id": "enrollment_pct",
      "name": "Early childhood enrollment rate, ages 3-4 (%)",
      "prefix": "",
      "suffix": "%",
      "decimals": 1,
      "source": "NIEER + Head Start (US); SELCCA (Canada); OECD (Nordics).",
      "description": "Share of children aged 3-4 enrolled in publicly funded early education programs. US: state pre-K + Head Start. Nordics: OECD ISCED 0, ages 3-5. Canada: SELCCA, ages 4-5. Age bands differ slightly across countries.",
      "caveat": "Not directly comparable across countries. US: public programs only, ages 3-4. Nordics: all formal ECEC, ages 3-5. Canada: all care arrangements, ages 0-5."
    },
    {
      "id": "gdp_per_child_0_4",
      "name": "GDP per child aged 0-4 (millions USD)",
      "prefix": "$",
      "suffix": "M",
      "decimals": 2,
      "source": "BEA (US); Statistics Canada; Eurostat/national agencies; FRED exchange rates.",
      "description": "Total GDP divided by population aged 0-4, converted to USD.",
      "caveat": "GDP converted to USD at market exchange rates. International comparisons are sensitive to currency fluctuations."
    },
    {
      "id": "workforce_share_pct",
      "name": "Childcare workers as share of workforce (%)",
      "prefix": "",
      "suffix": "%",
      "decimals": 2,
      "source": "BLS OEWS (US); national statistical agencies.",
      "description": "Childcare workers as a percentage of total employment.",
      "caveat": "Occupation definitions differ. US: SOC 39-9011 (childcare workers only). Nordics: ISCO/SSYK 5311 + 2342/2343 (childcare workers + preschool teachers). Canada: NOC 422 (broader paraprofessional group, not childcare-exclusive)."
    }
  ],
